# Database
DATABASE_URL=postgresql+asyncpg://aiva:aiva@localhost:5432/ai_visibility_audit

# Gemini — query generation, sentiment classification, and embeddings.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Exa — site/competitor discovery during prompt generation
EXA_API_KEY=...

# DataForSEO — Google AI Overview tracking + keyword signals.
# Login = your account email. Password = the API password shown in the
# DataForSEO dashboard (not your account login password).
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Bright Data — ChatGPT / Gemini / Google AI Mode sources.
# Sign up at https://brightdata.com/ and generate a token under
# Account Settings → API tokens. Billed per record.
BRIGHTDATA_API_KEY=

# Per-source dataset IDs from the Bright Data dashboard. The ChatGPT
# default below is Bright Data's public tutorial ID; override if yours
# differs. Gemini and Google AI Mode have no public defaults — set
# them to enable the corresponding source.
BRIGHTDATA_CHATGPT_DATASET_ID=gd_m7aof0k82r803d5bjm
# Bright Data's Gemini source does not accept country=PL. For
# Polish-market targeting on Google's AI surface, prefer
# BRIGHTDATA_GOOGLE_AI_MODE_DATASET_ID below.
BRIGHTDATA_GEMINI_DATASET_ID=
# Google AI Mode (the AI panel inside google.com search). Accepts
# country=PL.
BRIGHTDATA_GOOGLE_AI_MODE_DATASET_ID=

# API authentication
API_KEY=change-me-to-a-random-string

# App
APP_ENV=development
